#!/usr/bin/env bash
# =============================================================================
# config.env - Configuração centralizada para criação de templates Proxmox VE
# =============================================================================
# Este arquivo contém todas as variáveis configuráveis do projeto.
# Edite conforme o seu ambiente antes de executar os scripts.
# =============================================================================

# -----------------------------------------------------------------------------
# STORAGE
# -----------------------------------------------------------------------------
# Nome do storage pool do Proxmox onde os discos das VMs serão criados.
# Exemplos: local-lvm, cephfs-lvm, local-zfs, nfs-storage
STORAGE_POOL="cephfs-lvm"

# Storage para snippets Cloud-Init (deve ter content type 'snippets' habilitado).
# Em clusters, use um storage compartilhado (CephFS, NFS) para que os snippets
# estejam disponíveis em todos os nós. Para habilitar snippets no storage:
#   pvesm set <storage> --content images,rootdir,snippets
SNIPPETS_STORAGE="cephfs-lvm"

# Diretório onde as imagens cloud e ISOs serão baixadas temporariamente.
DOWNLOAD_DIR="/var/lib/vz/template/iso"

# -----------------------------------------------------------------------------
# REDE
# -----------------------------------------------------------------------------
# Bridge de rede padrão do Proxmox para conectar as VMs.
BRIDGE_NET="vmbr0"

# -----------------------------------------------------------------------------
# CLOUD-INIT (Linux)
# -----------------------------------------------------------------------------
# Usuário padrão criado pelo Cloud-Init nas VMs Linux.
CI_USER="mecloud360"

# Senha padrão do Cloud-Init (será aplicada ao usuário acima).
# ATENÇÃO: Para produção, prefira autenticação por chave SSH.
CI_PASSWORD='Informe_Sua_Senha'

# Caminho para o arquivo de chave pública SSH (opcional).
# Se definido, será usado para autenticação SSH nas VMs clonadas.
# Deixe vazio para usar apenas autenticação por senha.
CI_SSHKEY=""

# Configuração de rede padrão do Cloud-Init.
# Opções: "dhcp" ou "static" (se static, defina CI_IP, CI_GW, CI_MASK abaixo)
CI_NETWORK="dhcp"

# Configurações de IP estático (usadas apenas se CI_NETWORK="static")
CI_IP=""
CI_GW=""
CI_MASK="24"
CI_DNS=""
CI_SEARCHDOMAIN=""

# -----------------------------------------------------------------------------
# CLOUDBASE-INIT (Windows)
# -----------------------------------------------------------------------------
# Usuário administrador para templates Windows.
WIN_ADMIN_USER="Administrator"

# Senha do administrador Windows.
WIN_ADMIN_PASSWORD='Informe_Sua_Senha'

# -----------------------------------------------------------------------------
# VMID - Mapeamento de IDs para cada template
# -----------------------------------------------------------------------------
# Os VMIDs devem ser únicos no cluster Proxmox.
# Faixa reservada para templates: 9001-9099
VMID_UBUNTU_2404=9001
VMID_UBUNTU_2604=9009
VMID_DEBIAN_12=9002
VMID_DEBIAN_13=9003
VMID_CENTOS_STREAM_9=9004
VMID_ROCKY_8=9005
VMID_ROCKY_9=9006
VMID_WIN_2022=9007
VMID_WIN_2025=9008

# -----------------------------------------------------------------------------
# RECURSOS PADRÃO DAS VMs TEMPLATE
# -----------------------------------------------------------------------------
# Recursos de hardware padrão para templates Linux.
LINUX_MEMORY=2048
LINUX_CORES=2
LINUX_DISK_RESIZE="32G"

# Recursos de hardware padrão para templates Windows.
WIN_MEMORY=8192
WIN_CORES=4
WIN_DISK_SIZE="64"

# -----------------------------------------------------------------------------
# URLs DAS CLOUD IMAGES (Linux)
# -----------------------------------------------------------------------------
URL_UBUNTU_2404="https://cloud-images.ubuntu.com/noble/current/noble-server-cloudimg-amd64.img"
URL_UBUNTU_2604="https://cloud-images.ubuntu.com/resolute/current/resolute-server-cloudimg-amd64.img"
URL_DEBIAN_12="https://cloud.debian.org/images/cloud/bookworm/latest/debian-12-genericcloud-amd64.qcow2"
URL_DEBIAN_13="https://cloud.debian.org/images/cloud/trixie/latest/debian-13-genericcloud-amd64.qcow2"
URL_CENTOS_STREAM_9="https://cloud.centos.org/centos/9-stream/x86_64/images/CentOS-Stream-GenericCloud-9-latest.x86_64.qcow2"
URL_ROCKY_8="https://dl.rockylinux.org/pub/rocky/8/images/x86_64/Rocky-8-GenericCloud.latest.x86_64.qcow2"
URL_ROCKY_9="https://dl.rockylinux.org/pub/rocky/9/images/x86_64/Rocky-9-GenericCloud.latest.x86_64.qcow2"

# -----------------------------------------------------------------------------
# URLs DAS ISOs (Windows)
# -----------------------------------------------------------------------------
URL_VIRTIO_ISO="https://fedorapeople.org/groups/virt/virtio-win/direct-downloads/stable-virtio/virtio-win.iso"
URL_WIN_2022_ISO=""  # Requer download manual da Microsoft (Evaluation Center)
URL_WIN_2025_ISO=""  # Requer download manual da Microsoft (Evaluation Center)

# -----------------------------------------------------------------------------
# OPÇÕES AVANÇADAS
# -----------------------------------------------------------------------------
# Habilitar QEMU Guest Agent nos templates (recomendado).
ENABLE_QEMU_AGENT=true

# Habilitar fstrim em discos clonados (recomendado para thin provisioning).
ENABLE_FSTRIM=true

# Remover imagens baixadas após criação do template.
CLEANUP_IMAGES=true

# Nível de log: DEBUG, INFO, WARN, ERROR
LOG_LEVEL="INFO"

# Arquivo de log.
LOG_FILE="/var/log/proxmox-template-scripts.log"
